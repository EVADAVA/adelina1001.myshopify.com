    {%- if template == 'index' -%}
      <link rel="preload" as="image" href="//www.adelina.world/cdn/shop/files/01_7ac3c130-55c6-455d-86bd-7dfdf72e48e7_1200x.jpg?v=1661879322" fetchpriority="high" media="(min-width: 641px)">
