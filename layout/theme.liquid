<!doctype html>

<html class="no-js" lang="{{ shop.locale }}">
  <head>
  {%- comment -%} ── Google Analytics 4 — Consent Mode v2 (GDPR) ──────────────────────
    Consent defaults set to DENIED before gtag.js loads.
    Shopify Customer Privacy controls visitor consent.
    This satisfies GDPR ePrivacy + Google Consent Mode v2 requirements.
  {%- endcomment -%}
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      'analytics_storage':    'denied',
      'ad_storage':           'denied',
      'ad_user_data':         'denied',
      'ad_personalization':   'denied',
      'wait_for_update':      1500
    });
    gtag('js', new Date());
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CHLZQ63VJV"></script>
  <script>
    gtag('config', 'G-CHLZQ63VJV', { 'anonymize_ip': true });
  </script>
  {%- comment -%} ── / Google Analytics 4 ──────────────────────────────────────────── {%- endcomment -%}

