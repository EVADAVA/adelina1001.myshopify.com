{%- capture section_settings -%}
{
  "type": "drawer",
  "itemCount": {{ cart.item_count }},
  "drawer": true,
  "hasShippingEstimator": false
}
{%- endcapture -%}

<div id="sidebar-cart" class="Drawer Drawer--fromRight" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{{ 'cart.general.title' | t }}" data-section-id="cart" data-section-type="cart" data-section-settings='{{ section_settings }}'>
  <div class="Drawer__Header Drawer__Header--bordered Drawer__Container">
    <span class="Drawer__Title Heading u-h4">{{ 'cart.general.title' | t }}</span>
    <button class="Drawer__Close Icon-Wrapper--clickable" data-action="close-drawer" data-drawer-id="sidebar-cart" aria-label="{{ 'header.navigation.close_cart' | t }}">
      {%- render 'icon' with 'close' -%}
    </button>
  </div>

  <form class="Cart Drawer__Content" action="{{ routes.cart_url }}" method="POST" novalidate>
    <div class="Drawer__Main" data-scrollable>
      {%- if settings.cart_show_free_shipping_threshold -%}
        {%- assign threshold_cents = settings.cart_free_shipping_threshold | times: 100 -%}
        <div class="Cart__ShippingNotice Text--subdued">
          <div class="Drawer__Container">
            {%- if cart.total_price >= threshold_cents -%}
              <p>{{ 'cart.general.free_shipping' | t }}</p>
            {%- else -%}
              {%- assign remaining_cents = threshold_cents | minus: cart.total_price -%}
              <p>{{ 'cart.general.free_shipping_remaining_html' | t: remaining_amount: remaining_cents | money_without_trailing_zeros }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if cart.item_count == 0 -%}
        <div class="Drawer__Container">
          <p class="Cart__Empty Heading u-h5">{{ 'cart.general.empty' | t }}</p>
        </div>
      {%- else -%}
        <div class="Drawer__Container">
          <input type="hidden" name="attributes[collection_mobile_items_per_row]" value="">
          <input type="hidden" name="attributes[collection_desktop_items_per_row]" value="">
          {% render 'cart-items' %}
        </div>
      {%- endif -%}
    </div>

    {%- unless cart.item_count == 0 -%}
      <div class="Drawer__Footer" data-drawer-animated-bottom>
        {%- capture shipping_and_taxes_notice -%}{{ 'cart.general.shipping_and_taxes_notice' | t }}{%- endcapture -%}

        <div class="Cart__Details">
          {%- if settings.cart_enable_notes -%}
            <button type="button" class="Cart__NoteButton Button Button--plain" data-action="toggle-cart-note" aria-expanded="false">
              {%- if cart.note == blank -%}
                {{ 'cart.general.add_note' | t }}
              {%- else -%}
                {{ 'cart.general.edit_note' | t }}
              {%- endif -%}
            </button>
          {%- endif -%}

          {%- if shipping_and_taxes_notice != blank -%}
            <p class="Cart__Taxes Text--subdued">{{ shipping_and_taxes_notice }}</p>
          {%- endif -%}
        </div>

        {%- if cart.cart_level_discount_applications.size > 0 -%}
          <div class="Cart__DiscountList">
            {%- for discount_application in cart.cart_level_discount_applications -%}
              <p class="Cart__Discount">
                {%- render 'icon' with 'sale' -%}
                {{ 'cart.general.discount' | t }} ({{ discount_application.title }}): 
                -<span data-money-convertible>{{ discount_application.total_allocated_amount | money_without_trailing_zeros }}</span>
              </p>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <button type="submit" name="checkout" class="Cart__Checkout Button Button--primary Button--full">
          <span>{{ 'cart.general.checkout' | t }}</span>
          <span class="Button__SeparatorDot"></span>
          <span data-money-convertible>{{ cart.total_price | money_without_trailing_zeros }}</span>
        </button>

        <button type="button" class="Cart__ContinueShopping Button Button--secondary Button--full" data-action="close-drawer" data-drawer-id="sidebar-cart">
          {{ 'cart.general.continue_shopping' | t }}
        </button>

        {%- if settings.cart_enable_notes -%}
          <div class="Cart__OffscreenNoteContainer" aria-hidden="true">
            <div class="Form__Item">
              <label for="cart-note" class="visually-hidden">{{ 'cart.general.note_placeholder' | t }}</label>
              <textarea class="Cart__Note Form__Textarea" name="note" id="cart-note" rows="3" placeholder="{{ 'cart.general.note_placeholder' | t }}" data-scrollable>{{ cart.note }}</textarea>
            </div>
            <div class="Cart__NoteActions">
              <button type="button" class="Button Button--secondary Button--full" data-action="close-cart-note">{{ 'cart.general.cancel' | t }}</button>
              <button type="button" class="Button Button--primary Button--full" data-action="save-cart-note">{{ 'cart.general.save_note' | t }}</button>
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}
  </form>
</div>

