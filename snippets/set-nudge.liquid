  var IDX = CFG.variantIndex, FAMS = {};
  CFG.families.forEach(function(f){ FAMS[f.key] = f; });

  function root(){
    if (window.Shopify && Shopify.routes && Shopify.routes.root) return Shopify.routes.root;
    var m = location.pathname.match(/^\/[a-z]{2}(?:-[a-z]{2})?\//i);
    return m ? m[0] : '/';
  }
  function money(cents){ return '€' + Math.round(cents/100).toLocaleString('de-DE'); }
  function esc(s){ var d=document.createElement('div'); d.textContent=s==null?'':s; return d.innerHTML; }
  function roleLabel(r){ return r==='Earrings'?'Earrings':r; }

  // Build nudge cards from current cart line items.
  function cardsFor(items){
    var byFam = {};
    items.forEach(function(li){
      var hit = IDX[String(li.variant_id)];
      if (!hit) return;
      byFam[hit.f] = byFam[hit.f] || {roles:{}, hasSet:false};
      if (hit.role==='Set') byFam[hit.f].hasSet = true;
      else byFam[hit.f].roles[hit.role] = true;
    });

    var out = [];
    Object.keys(byFam).forEach(function(key){
      var st = byFam[key], f = FAMS[key];
      if (!f || st.hasSet) return;
      var presentPieces = f.pieces.filter(function(p){ return st.roles[p.role]; });
      if (presentPieces.length < 2) return;
      var missing = f.pieces.filter(function(p){ return !st.roles[p.role]; });
      var save = f.pieceSum - f.set.price;
      if (save <= 0) return;
      out.push({ f:f, presentPieces:presentPieces, missing:missing, save:save });
    });
    // best savings first; cap to 2 cards to avoid clutter
    out.sort(function(a,b){ return b.save - a.save; });
    return out.slice(0,2);
  }

  function cardHtml(c){
    var f=c.f, full = c.missing.length===0;
    var title, text;
    if (full){
      title = 'You have the full ' + esc(f.short) + ' set';
      text  = 'Swap your three pieces for the <b>' + esc(f.short) +
              ' Set</b> and pay ' + money(f.set.price) +
              ' — <span class="SetNudge__Save">save ' + money(c.save) + '</span>.';
    } else {
      var miss = c.missing.map(function(p){ return roleLabel(p.role); }).join(' & ');
      title = "You're one piece from the " + esc(f.short) + ' set';
      text  = 'Add the <b>' + esc(miss) + '</b> as part of the <b>' + esc(f.short) +
              ' Set</b>: ' + money(f.set.price) + ' for all three (' + money(f.pieceSum) +
              ' separately, <span class="SetNudge__Save">save ' + money(c.save) + '</span>).';
    }
    var remove = c.presentPieces.map(function(p){ return p.variant; }).join(',');
    var img = f.set.image ? '<img class="SetNudge__Thumb" src="' + esc(f.set.image) +
              '&width=120" alt="" loading="lazy">' : '';
    return '<div class="SetNudge__Card">' + img +
      '<div class="SetNudge__Body">' +
        '<p class="SetNudge__Title">' + title + '</p>' +
        '<p class="SetNudge__Text">' + text + '</p>' +
        '<button type="button" class="SetNudge__Btn" data-nudge-to-set ' +
          'data-set-variant="' + f.set.variant + '" data-remove="' + remove + '">' +
          (full ? 'Switch to the Set' : 'Complete the Set') + ' →</button>' +
      '</div></div>';
  }

  function paint(items){
    var hosts = document.querySelectorAll('[data-set-nudge]');
    if (!hosts.length) return;
    var cards = cardsFor(items||[]);
    var html = cards.map(cardHtml).join('');
    hosts.forEach(function(h){ h.innerHTML = html; });
  }

  var t=null;
  function render(){
    if (!document.querySelector('[data-set-nudge]')) return;
    clearTimeout(t);
    t = setTimeout(function(){
      fetch(root()+'cart.js', {headers:{'Accept':'application/json'}, credentials:'same-origin'})
        .then(function(r){ return r.json(); })
        .then(function(c){ paint(c.items||[]); })
        .catch(function(){});
    }, 60);
  }

  // ── Swap pieces -> Set ─────────────────────────────────────────────────────
  // 1) /cart/update.js zeros the loose pieces and adds the Set in one atomic call
  //    (verified: update.js adds a variant that isn't yet in the cart).
  // 2) Re-render the visible cart with a GET /cart?view=... and DOM replacement —
  //    the SAME proven path snippets/cart-items.liquid uses (update.js does not
  //    reliably return the `sections` payload, so we don't depend on it).
  function refreshCartUI(data){
    var isDrawer = !!document.getElementById('sidebar-cart');
    var view = isDrawer ? 'drawer' : 'ajax';
    return fetch(root()+'cart?view='+view+'&timestamp='+Date.now(), {
      method:'GET', credentials:'same-origin', headers:{'X-Requested-With':'XMLHttpRequest'}
    })
    .then(function(r){ return r.text(); })
    .then(function(h){
      var tmp=document.createElement('div'); tmp.innerHTML=h;
      var current = document.getElementById('sidebar-cart') || document.querySelector('[data-section-type="cart"]');
      var fresh   = tmp.querySelector('#sidebar-cart') || tmp.querySelector('[data-section-type="cart"]');
      if (current && fresh && current.id === 'sidebar-cart'){
        var cM=current.querySelector('.Drawer__Main'),  fM=fresh.querySelector('.Drawer__Main');
        var cF=current.querySelector('.Drawer__Footer'), fF=fresh.querySelector('.Drawer__Footer');
        if (cM && fM) cM.replaceWith(fM);
        if (cF && fF) cF.replaceWith(fF);
        else if (cF) cF.remove();
        else if (fF){ var form=current.querySelector('form.Cart'); if (form) form.appendChild(fF); }
      } else if (current && fresh){
        current.replaceWith(fresh);
      }
      document.querySelectorAll('.Header__CartCount').forEach(function(el){ el.textContent=data.item_count; });
      document.querySelectorAll('.Header__CartDot').forEach(function(el){ el.classList.toggle('is-visible', data.item_count>0); });
      window.dispatchEvent(new CustomEvent('cart:updated',{detail:data}));   // local-store sync + recompute
      window.dispatchEvent(new CustomEvent('adl:cart:rendered'));
    });
  }

  function swap(btn){
    var setV = parseInt(btn.getAttribute('data-set-variant'),10);
    var remove = (btn.getAttribute('data-remove')||'').split(',').filter(Boolean);
    var updates = {}; remove.forEach(function(v){ updates[v]=0; }); updates[setV]=1;
    btn.disabled = true;
    var oldErr = btn.parentElement.querySelector('.SetNudge__Err'); if (oldErr) oldErr.remove();

    fetch(root()+'cart/update.js', {
      method:'POST', credentials:'same-origin',
      headers:{'Accept':'application/json','Content-Type':'application/json'},
      body: JSON.stringify({ updates:updates })
    })
    .then(function(r){ return r.json().then(function(d){ return {ok:r.ok,d:d}; }); })
    .then(function(res){
      if (!res.ok) throw new Error((res.d&&(res.d.description||res.d.message))||'Error');
      return refreshCartUI(res.d);
    })
    .catch(function(e){
      btn.disabled=false;
      var p=document.createElement('p'); p.className='SetNudge__Err';
      p.textContent = (e&&e.message) ? e.message : 'Could not update the cart. Please try again.';
      btn.insertAdjacentElement('afterend', p);
    });
  }

  document.addEventListener('click', function(e){
    var btn = e.target.closest && e.target.closest('[data-nudge-to-set]');
    if (!btn) return;
    e.preventDefault(); e.stopImmediatePropagation();
    swap(btn);
  }, true);

  window.addEventListener('cart:updated', render);
  window.addEventListener('adl:cart:rendered', render);
  if (document.readyState!=='loading') render();
  else document.addEventListener('DOMContentLoaded', render);
})();
</script>