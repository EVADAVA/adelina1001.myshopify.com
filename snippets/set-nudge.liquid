{%- comment -%}
  set-nudge.liquid — «Добей до сета» / Complete-the-Set nudge.
  Self-contained: family config (generated from live products) + logic + styles.
  Renders a card inside [data-set-nudge] (lives in snippets/cart-items.liquid) when
  the cart holds >=2 pieces of one family but not its Set. One button swaps the loose
  pieces for the discounted Set via a single /cart/update.js call.
  Regenerate config with /tmp/gen_snippet.py if products/prices change.
{%- endcomment -%}
<style>
  .SetNudge{margin:14px 0 4px}
  .SetNudge__Card{display:flex;gap:12px;align-items:flex-start;padding:14px;
    border:1px solid var(--border-color,#e3ddd4);border-radius:6px;
    background:var(--secondary-background,#faf7f2)}
  .SetNudge__Card+.SetNudge__Card{margin-top:10px}
  .SetNudge__Thumb{flex:0 0 56px;width:56px;height:56px;border-radius:4px;object-fit:cover}
  .SetNudge__Body{flex:1 1 auto;min-width:0}
  .SetNudge__Title{font-weight:600;font-size:13px;line-height:1.35;margin:0 0 3px}
  .SetNudge__Text{font-size:12px;line-height:1.4;margin:0 0 9px;opacity:.85}
  .SetNudge__Save{font-weight:600}
  .SetNudge__Btn{display:inline-block;width:100%;padding:9px 12px;border:0;cursor:pointer;
    font-size:12px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;border-radius:4px;
    background:var(--button-background,#1c1c1c);color:var(--button-text-color,#fff);transition:opacity .15s}
  .SetNudge__Btn:hover{opacity:.85}
  .SetNudge__Btn[disabled]{opacity:.5;cursor:default}
  .SetNudge__Err{color:#c0392b;font-size:12px;margin:6px 0 0}
</style>
